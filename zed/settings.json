{
    "cli_default_open_behavior": "new_window",
    "cursor_shape": "bar",
    "outline_panel": {
        "dock": "left",
    },
    "collaboration_panel": {
        "dock": "left",
    },
    "git_panel": {
        "dock": "left",
    },
    "cursor_blink": false,
    "project_panel": {
        "dock": "left",
        "auto_fold_dirs": false,
        "auto_reveal_entries": true,
        "indent_size": 20.0,
        "folder_icons": true,
        "file_icons": true,
        "entry_spacing": "comfortable",
    },
    "ui_font_weight": 400.0,
    "agent_servers": {
        "codex-acp": {
            "default_config_options": {
                "fast-mode": "off",
                "reasoning_effort": "high",
                "mode": "full-access",
            },
            "type": "registry",
        },
    },
    "use_system_window_tabs": false,
    "show_edit_predictions": true,
    "format_on_save": "on",
    "languages": {
        "C++": {
            "formatter": {
                "external": {
                    "command": "clang-format",
                    "arguments": [
                        "--style=file:/Users/nagraver/.clang-format",
                        "--assume-filename={buffer_path}",
                    ],
                },
            },
        },
        "C": {
            "formatter": {
                "external": {
                    "command": "clang-format",
                    "arguments": [
                        "--style=file:/Users/nagraver/Documents/.clang-format",
                        "--assume-filename={buffer_path}",
                    ],
                },
            },
        },
        "Python": {
            "formatter": {
                "external": {
                    "command": "black",
                    "arguments": ["-", "--line-length", "120"],
                },
                // "language_server": {
                //     "name": "ruff",
                // },
            },
        },
    },
    "agent": {
        "notify_when_agent_waiting": "never",
        "sidebar_side": "right",
        "default_profile": "write",
        "dock": "right",
        "default_model": {
            "enable_thinking": true,
            "provider": "openai",
            "model": "gpt-5.3-codex",
        },
    },
    "ssh_connections": [
        {
            "host": "yelping-brown",
            "args": [],
            "projects": [
                {
                    "paths": ["/home/nagraver"],
                },
            ],
        },
        {
            "host": "xorek",
            "args": [],
            "projects": [
                {
                    "paths": ["/home/nagraver"],
                },
            ],
        },
    ],
    "edit_predictions": {
        "provider": "zed",
        "mode": "subtle",
    },
    "git": {
        "inline_blame": {
            "enabled": false,
        },
    },
    "tabs": {
        "activate_on_close": "left_neighbour",
        "file_icons": true,
        "git_status": true,
    },
    "autosave": {
        "after_delay": {
            "milliseconds": 100,
        },
    },
    "buffer_line_height": {
        "custom": 1.95,
    },
    "buffer_font_features": {
        "calt": false, // disable ligatures
    },
    "file_types": {
        "Helm": [
            "**/templates/**/*.tpl",
            "**/templates/**/*.yaml",
            "**/templates/**/*.yml",
            "**/helmfile.d/**/*.yaml",
            "**/helmfile.d/**/*.yml",
            "**/values*.yaml",
        ],
    },
    "current_line_highlight": "gutter",
    "icon_theme": {
        "mode": "dark",
        "light": "Catppuccin Mocha",
        "dark": "Catppuccin Mocha",
    },
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "One Dark Pro JB",
    },
    "tab_size": 4,
    "ui_font_size": 18,
    "buffer_font_size": 18,
    "agent_ui_font_size": 20.0,
    "agent_buffer_font_size": 18.0,
    "ui_font_family": "Inter",
    "buffer_font_family": "Hack Nerd Font",
}
