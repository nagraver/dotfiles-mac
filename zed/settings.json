{
    "cursor_blink": false,
    "project_panel": {
        "auto_fold_dirs": false,
        "auto_reveal_entries": true,
        "indent_size": 20.0,
        "folder_icons": true,
        "file_icons": true,
        "entry_spacing": "comfortable",
    },
    "ui_font_weight": 400.0,
    "agent_servers": {
        "codex-acp": {
            "default_config_options": {
                "mode": "auto",
                "model": "gpt-5.4",
                "reasoning_effort": "high",
            },
            "favorite_config_option_values": {
                "model": ["gpt-5.3-codex"],
            },
            "type": "registry",
        },
    },
    "use_system_window_tabs": false,
    "show_edit_predictions": true,
    "format_on_save": "on",
    "languages": {
        "C++": {
            "formatter": {
                "external": {
                    "command": "clang-format",
                    "arguments": [
                        "--style=file:/Users/nagraver/.clang-format",
                        "--assume-filename={buffer_path}",
                    ],
                },
            },
        },
        "C": {
            "formatter": {
                "external": {
                    "command": "clang-format",
                    "arguments": [
                        "--style=file:/Users/nagraver/Documents/.clang-format",
                        "--assume-filename={buffer_path}",
                    ],
                },
            },
        },
        "Python": {
            "formatter": {
                "external": {
                    "command": "black",
                    "arguments": ["-", "--line-length", "120"],
                },
            },
        },
    },
    "agent": {
        "default_profile": "write",
        "dock": "right",
        "default_model": {
            "enable_thinking": true,
            "provider": "openai",
            "model": "gpt-5.3-codex",
        },
    },
    "ssh_connections": [
        {
            "host": "labour-ivory",
            "args": [],
            "projects": [
                {
                    "paths": ["/home/nagraver"],
                },
            ],
        },
    ],
    "edit_predictions": {
        "provider": "zed",
        "mode": "subtle",
    },
    "git": {
        "inline_blame": {
            "enabled": false,
        },
    },
    "tabs": {
        "activate_on_close": "left_neighbour",
        "file_icons": true,
        "git_status": true,
    },
    "autosave": {
        "after_delay": {
            "milliseconds": 100,
        },
    },
    "buffer_line_height": {
        "custom": 1.95,
    },
    "buffer_font_features": {
        "calt": false, // disable ligatures
    },
    "current_line_highlight": "gutter",
    "icon_theme": "Catppuccin Mocha",
    "theme": "One Dark Pro",
    "tab_size": 4,
    "ui_font_size": 18,
    "buffer_font_size": 18,
    "agent_ui_font_size": 20.0,
    "agent_buffer_font_size": 18.0,
    "ui_font_family": "Inter",
    "buffer_font_family": "Hack Nerd Font",
}
